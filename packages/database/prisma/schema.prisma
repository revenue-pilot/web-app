// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// CORE TENANT & USER MANAGEMENT
// -----------------------------------------------------------------------------

enum Role {
  ADMIN       // Platform Administrator (SaaS Owner)
  AGENCY      // Agency Owner (White-label capabilities)
  CLIENT      // End Client User
}

model Organization {
  id              String         @id @default(uuid())
  name            String
  domain          String?        @unique
  logoUrl         String?
  brandColor      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  users           User[]
  clients         Client[]
  subscriptions   Subscription[]
  apiTokens       ApiToken[]
  whiteLabel      WhiteLabelConfig?
}

model User {
  id                      String           @id @default(uuid())
  email                   String           @unique
  name                    String?
  passwordHash            String?          // Nullable if using OAuth only
  role                    Role             @default(CLIENT)
  organizationId          String
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  // Profile Fields
  firstName               String?
  lastName                String?
  phone                   String?
  jobTitle                String?
  websiteUrl              String?
  country                 String?
  timezone                String?
  avatarUrl               String?

  // Security Toggles
  twoFactorEnabled        Boolean          @default(false)
  twoFactorSecret         String?
  twoFactorRecoveryCodes  String?

  organization            Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activityLogs            ActivityLog[]
  auditLogs               AuditLog[]
  preferences             UserPreference?
  loginHistory            LoginHistory[]
}

model UserPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  language            String   @default("en")
  timezone            String   @default("UTC")
  dateFormat          String   @default("YYYY-MM-DD")
  currency            String   @default("INR")
  theme               String   @default("light")
  density             String   @default("comfortable")
  sidebarMode         String   @default("expanded")
  
  // Notification Preferences
  emailProductUpdates Boolean  @default(true)
  emailBillingAlerts  Boolean  @default(true)
  emailSecurityAlerts Boolean  @default(true)
  emailMarketing      Boolean  @default(false)
  emailWeeklyReports  Boolean  @default(true)
  
  inAppActivity       Boolean  @default(true)
  inAppAiUpdates      Boolean  @default(true)
  inAppBillingEvents  Boolean  @default(true)
  inAppSupportUpdates Boolean  @default(true)
  
  // AI Configs
  aiModel             String   @default("gpt-4o")
  aiResponseLength    String   @default("medium")
  aiCreativityLevel   Float    @default(0.7)
  aiDefaultLanguage   String   @default("en")

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  device    String
  browser   String
  ipAddress String
  location  String
  loginTime DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id              String         @id @default(uuid())
  name            String
  industry        String?
  organizationId  String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adAccounts      AdAccount[]
  reports         Report[]
}

model WhiteLabelConfig {
  id              String         @id @default(uuid())
  organizationId  String         @unique
  customDomain    String?
  primaryColor    String?
  logoUrl         String?
  supportEmail    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// BILLING & SUBSCRIPTIONS
// -----------------------------------------------------------------------------

enum PlanTier {
  FREE
  STARTER
  GROWTH
  PROFESSIONAL
  AGENCY
  ENTERPRISE
}

model Subscription {
  id                 String         @id @default(uuid())
  organizationId     String
  tier               PlanTier       @default(FREE)
  status             String         // ACTIVE, CANCELED, PAST_DUE
  gatewayPaymentId   String?        // Razorpay order ID or Stripe session ID
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
}

model Invoice {
  id              String         @id @default(uuid())
  subscriptionId  String
  amount          Float
  status          String         // PAID, PENDING, FAILED
  pdfUrl          String?
  createdAt       DateTime       @default(now())

  subscription    Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// ADVERTISING CORE (CAMPAIGNS, ADS, BUDGETS)
// -----------------------------------------------------------------------------

enum Platform {
  GOOGLE_ADS
  META_ADS
  TIKTOK_ADS
}

model AdAccount {
  id              String         @id @default(uuid())
  clientId        String
  platform        Platform
  platformId      String         // External ID (e.g. Google Ads Account ID)
  status          String         // ACTIVE, DISCONNECTED
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaigns       Campaign[]
}

model Campaign {
  id              String         @id @default(uuid())
  adAccountId     String
  name            String
  status          String         // ACTIVE, PAUSED, REMOVED
  objective       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  adAccount       AdAccount      @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  adGroups        AdGroup[]
  budgets         Budget[]
  metrics         CampaignMetric[]
  automations     AutomationRule[]
  aiRecommendations AiRecommendation[]
}

model AdGroup {
  id              String         @id @default(uuid())
  campaignId      String
  name            String
  status          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads             Ad[]
  keywords        Keyword[]
}

model Ad {
  id              String         @id @default(uuid())
  adGroupId       String
  name            String
  headline        String?
  description     String?
  imageUrl        String?
  status          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  adGroup         AdGroup        @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
}

model Keyword {
  id              String         @id @default(uuid())
  adGroupId       String
  text            String
  matchType       String         // EXACT, PHRASE, BROAD
  status          String
  createdAt       DateTime       @default(now())

  adGroup         AdGroup        @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
}

model Budget {
  id              String         @id @default(uuid())
  campaignId      String
  amount          Float
  period          String         // DAILY, LIFETIME
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignMetric {
  id              String         @id @default(uuid())
  campaignId      String
  date            DateTime
  spend           Float          @default(0)
  impressions     Int            @default(0)
  clicks          Int            @default(0)
  conversions     Float          @default(0)
  roas            Float          @default(0)
  createdAt       DateTime       @default(now())

  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// AUTOMATION & AI
// -----------------------------------------------------------------------------

model AutomationRule {
  id              String         @id @default(uuid())
  campaignId      String?
  name            String
  condition       String         // Stored as JSON logic or string
  action          String         // Stored as JSON action payload
  status          String         // ACTIVE, PAUSED
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  campaign        Campaign?      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model AiRecommendation {
  id              String         @id @default(uuid())
  campaignId      String
  title           String
  description     String
  type            String         // BUDGET, CREATIVE, KEYWORD
  status          String         // PENDING, APPLIED, REJECTED
  createdAt       DateTime       @default(now())

  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// SYSTEM & REPORTING
// -----------------------------------------------------------------------------

model Report {
  id              String         @id @default(uuid())
  clientId        String
  name            String
  url             String?
  schedule        String?        // DAILY, WEEKLY, MONTHLY
  createdAt       DateTime       @default(now())

  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Notification {
  id              String         @id @default(uuid())
  title           String
  message         String
  type            String         // ALERT, INFO, SUCCESS
  isRead          Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

model ApiToken {
  id              String         @id @default(uuid())
  organizationId  String
  token           String         @unique
  name            String
  createdAt       DateTime       @default(now())

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id              String         @id @default(uuid())
  userId          String
  action          String
  resource        String
  details         String?
  createdAt       DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id              String         @id @default(uuid())
  userId          String
  description     String
  createdAt       DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// CREATIVE ASSETS & CAMPAIGN LINKS
// -----------------------------------------------------------------------------

model CreativeAsset {
  id              String             @id @default(uuid())
  organizationId  String
  clientId        String
  assetType       String             // IMAGE, VIDEO, LOGO, DOCUMENT
  assetName       String
  fileUrl         String
  thumbnailUrl    String?
  width           Int?
  height          Int?
  duration        Float?
  format          String
  createdAt       DateTime           @default(now())

  versions        CreativeVersion[]
}

model CreativeVersion {
  id              String             @id @default(uuid())
  assetId         String
  ratio           String             // 1:1, 9:16, 1.91:1, 4:1, 16:9
  width           Int
  height          Int
  generatedByAI   Boolean            @default(false)
  status          String             // READY, CROPPING

  asset           CreativeAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model CampaignAsset {
  id              String             @id @default(uuid())
  campaignId      String
  assetId         String
  platform        String             // GOOGLE, META, BOTH
  placement       String             // FEED, STORY, REEL, SEARCH, DISPLAY
}

model SubscriptionPlan {
  id           String        @id @default(uuid())
  name         String        @unique
  monthlyPrice Float
  annualPrice  Float
  features     PlanFeature[]
}

model PlanFeature {
  id         String           @id @default(uuid())
  planId     String
  featureKey String
  enabled    Boolean          @default(true)

  plan       SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model FeatureRegistry {
  id          String @id @default(uuid())
  featureName String
  featureKey  String @unique
  module      String
}

model UsageTracking {
  id             String   @id @default(uuid())
  organizationId String
  featureKey     String
  usageCount     Int      @default(0)
  updatedAt      DateTime @updatedAt
}
