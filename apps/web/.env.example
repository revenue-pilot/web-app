# =============================================================================
# RevenuePilot Web — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit your .env file to source control.
# =============================================================================

PORT=3000
NODE_ENV=production

# =============================================================================
# API ROUTING
# =============================================================================
# BACKEND_URL: Internal service URL for the NestJS API used by Next.js rewrites.
# In Railway: set to the private network URL of the API service (e.g. http://api.railway.internal:3001)
# In Docker Compose: set to the service name (e.g. http://api:3001)
# In local dev: leave unset (defaults to http://localhost:3001)
# BACKEND_URL="http://api.railway.internal:3001"

# Public API base path — used by browser fetch calls in components
NEXT_PUBLIC_API_URL="/api"

# =============================================================================
# NEXTAUTH
# =============================================================================
# Set to the full URL of this Next.js app in production
NEXTAUTH_URL="https://app.revenuepilot.in"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="a697109a9c16857945f76ae6d9892f45c6fb1cc27143ece397407bcb30419f54"

# =============================================================================
# OAUTH CREDENTIALS (Optional — enables Google One-tap login)
# =============================================================================
# GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_SECRET="your-google-client-secret"

# =============================================================================
# PAYMENT GATEWAYS (Public keys only)
# =============================================================================
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_SyH7yUYk6Xnj4n"
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# =============================================================================
# ANALYTICS & MONITORING (Optional)
# =============================================================================
# NEXT_PUBLIC_GA_ID="G-..."
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# NEXT_PUBLIC_SENTRY_DSN="https://...@o....ingest.sentry.io/..."
