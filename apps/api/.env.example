# =============================================================================
# RevenuePilot API — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit your .env file to source control.
# =============================================================================

# Server
PORT=3001
NODE_ENV=production

# =============================================================================
# DATABASE (Supabase PostgreSQL — required for production)
# =============================================================================
# Get from: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres:<Pass>@db.lkelayolzgqypckwhqxm.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:<Pass>@db.lkelayolzgqypckwhqxm.supabase.co:5432/postgres"

# =============================================================================
# SECURITY
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# Frontend URL (used in email links — set to your production domain)
FRONTEND_URL="https://app.Revenuepilot.com"

# Allowed CORS origins (comma-separated for multiple)
# FRONTEND_URL="https://app.Revenuepilot.com,https://staging.Revenuepilot.com"

# =============================================================================
# AI PROVIDERS (at least one required)
# =============================================================================
# OpenAI / Compatible proxy
OPENAI_API_KEY="sk-live.."
OPENAI_BASE_URL="https://api.aicredits.in/v1"

# Anthropic Claude (optional — used as fallback)
# ANTHROPIC_API_KEY="sk-ant-..."

# Google Gemini (optional — used as fallback)
# GEMINI_API_KEY="AIzaSy..."

# =============================================================================
# BILLING GATEWAYS
# =============================================================================
# Razorpay (Primary for Indian market)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET="..."

# Stripe (Optional — international payments)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================================================
# TRANSACTIONAL EMAIL (Resend — required for production)
# =============================================================================
RESEND_API_KEY=""
EMAIL_FROM="RevenuePilot <noreply@revenuepilot.in>"

# =============================================================================
# CLOUD STORAGE (AWS S3 or Cloudflare R2)
# =============================================================================
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="ap-south-1"
AWS_BUCKET_NAME="Revenuepilot-production-storage"

# =============================================================================
# REDIS (BullMQ Queue — Railway Redis Plugin or Upstash)
# =============================================================================
REDIS_URL="redis://default:<Token>@curious-starfish-84154.upstash.io:6379"
# For TLS (Upstash/Railway Redis with TLS):
# REDIS_URL="rediss://..."
